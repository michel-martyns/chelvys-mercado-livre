# ===========================================
# CREDENCIAIS WEDROP
# ===========================================
WEDROP_EMAIL=seu_email@email.com
WEDROP_PASSWORD=sua_senha

# Catálogo principal
WEDROP_CATALOG_ID=32425
WEDROP_BASE_URL=https://dash.wedrop.com.br

# ===========================================
# CREDENCIAIS MERCADO LIVRE API
# ===========================================
# Obter em: https://developers.mercadolivre.com.br/
MERCADOLIVRE_APP_ID=
MERCADOLIVRE_SECRET_KEY=
MERCADOLIVRE_ACCESS_TOKEN=
MERCADOLIVRE_REFRESH_TOKEN=

# ===========================================
# CONFIGURAÇÕES GERAIS
# ===========================================
ENV=development
LOG_LEVEL=INFO

# CDN para imagens (opcional - configurar se usar)
CDN_PROVIDER=
CDN_API_KEY=

# ===========================================
# CONFIGURAÇÕES DE PRECIFICAÇÃO
# ===========================================
# Markup padrão (30% = 1.3)
DEFAULT_MARKUP=1.3

# Considerar taxa do Mercado Livre (~15%)
ML_FEE_RATE=0.15
